{
  "name": "solana-skill-quality-gate",
  "version": "3.0.0",
  "description": "Quality and safety gate for Solana AI Kit skills",
  "type": "module",
  "main": "scripts/skillqa.mjs",
  "homepage": "https://github.com/xDzaky/solana-skill-quality-gate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xDzaky/solana-skill-quality-gate.git"
  },
  "scripts": {
    "test": "node scripts/test.mjs",
    "audit:good": "node scripts/skillqa.mjs audit scripts/fixtures/good-skill",
    "audit:bad": "node scripts/skillqa.mjs audit scripts/fixtures/bad-skill --strict",
    "audit:self": "node scripts/skillqa.mjs audit .",
    "score:good": "node scripts/skillqa.mjs score scripts/fixtures/good-skill --json",
    "score:bad": "node scripts/skillqa.mjs score scripts/fixtures/bad-skill --json",
    "score:self": "node scripts/skillqa.mjs score . --json",
    "report:good": "node scripts/skillqa.mjs report scripts/fixtures/good-skill --out examples/audit-report-good.md",
    "report:bad": "node scripts/skillqa.mjs report scripts/fixtures/bad-skill --out examples/audit-report-bad.md",
    "report:self": "node scripts/skillqa.mjs report . --out examples/audit-report-self.md",
    "batch": "node scripts/skillqa.mjs batch scripts/fixtures/benchmark-samples --json --out examples/batch-review.json",
    "batch:md": "node scripts/skillqa.mjs batch scripts/fixtures/benchmark-samples --markdown --out examples/batch-review.md",
    "sarif:bad": "node scripts/skillqa.mjs report scripts/fixtures/bad-skill --sarif --out examples/bad-skill.sarif",
    "gate": "node scripts/skillqa.mjs score . --json --fail-under 90"
  },
  "keywords": [
    "solana",
    "solana-ai-kit",
    "ai-skills",
    "claude-code",
    "quality-gate",
    "skill-bounty",
    "static-analysis",
    "security-scanner",
    "sarif",
    "developer-tools",
    "supply-chain",
    "agent-skills"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
